{
  "$schema": "./packages/shared/ekg-config.schema.json",
  "repos": [
    {
      "url": "https://github.com/example/user-service",
      "branch": "main",
      "serviceMappings": {
        "src/": "UserService"
      }
    }
  ],
  "ignoreDirs": [
    "node_modules",
    "dist",
    "build",
    ".git",
    "coverage",
    "vendor",
    "__tests__",
    "test"
  ],
  "supportedExtensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"],
  "mcpAdapters": [
    {
      "id": "datadog",
      "enabled": false,
      "transport": "stdio",
      "env": { "DD_API_KEY": "${DD_API_KEY}", "DD_APP_KEY": "${DD_APP_KEY}", "DD_SITE": "${DD_SITE}" },
      "serviceMapping": "auto",
      "capabilities": ["metrics", "traces", "errors", "alarms"],
      "priority": 10
    },
    {
      "id": "atlassian",
      "enabled": false,
      "transport": "http",
      "env": {
        "ATLASSIAN_BASE_URL": "${ATLASSIAN_BASE_URL}",
        "ATLASSIAN_EMAIL": "${ATLASSIAN_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
      },
      "serviceMapping": "auto",
      "capabilities": ["tickets", "docs"],
      "priority": 5
    },
    {
      "id": "mixpanel",
      "enabled": false,
      "transport": "http",
      "env": {
        "MIXPANEL_PROJECT_ID": "${MIXPANEL_PROJECT_ID}",
        "MIXPANEL_SERVICE_ACCOUNT": "${MIXPANEL_SERVICE_ACCOUNT}",
        "MIXPANEL_API_SECRET": "${MIXPANEL_API_SECRET}"
      },
      "serviceMapping": "auto",
      "capabilities": ["usage"],
      "priority": 5
    },
    {
      "id": "loki",
      "enabled": false,
      "transport": "http",
      "env": {
        "LOKI_BASE_URL": "${LOKI_BASE_URL}",
        "LOKI_TENANT_ID": "${LOKI_TENANT_ID}",
        "LOKI_TOKEN": "${LOKI_TOKEN}"
      },
      "serviceMapping": { "field": "service_name", "pattern": "{service}" },
      "capabilities": ["logs", "errors"],
      "priority": 5
    }
  ]
}
