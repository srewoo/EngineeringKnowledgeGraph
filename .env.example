# =============================================================================
# EKG / CodeSage configuration
# =============================================================================
# Copy this file to .env (which is in .gitignore) and fill in real values.
#
# IMPORTANT: don't leave dotenv values as `...` — that literal three-dot
# placeholder is loaded as a string and rejected by the SDK at the first API
# call. Either set the real value or comment the whole line out.

# -----------------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------------

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ekg-local-dev

# Local data directory (where data/repos and SQLite live).
DATA_DIR=./data

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Git access + bulk discovery
# Required for: ingest_repo, bulk_ingest, gitlab_get_mr.
# -----------------------------------------------------------------------------

# Personal access token. NEVER COMMIT THIS FILE WITH A REAL TOKEN.
GIT_TOKEN=

# GitLab base URL (override for self-hosted instances).
GITLAB_URL=https://gitlab.com

# Comma-separated GitLab group IDs for bulk_ingest / discover_repos.
GITLAB_GROUP_IDS=

# Repo size limit (MB) — repos larger than this are skipped during bulk_ingest.
MAX_REPO_SIZE_MB=1024

# Per-repo ingestion timeout (ms). Min 60000, default 600000 (10 min).
INGEST_TIMEOUT_MS=600000

# Bulk ingestion concurrency (1-32).
BULK_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Phase 2 — embeddings (opt-in)
# Required for: search_semantic, vector mode of search_codebase, ask_question
# / answer_question with semantic retrieval.
# -----------------------------------------------------------------------------

EKG_EMBEDDINGS_ENABLED=true

# Provider: ollama | openai | voyage
EKG_EMBEDDING_PROVIDER=ollama
EKG_EMBEDDING_MODEL=nomic-embed-text

# Ollama URL (used by any *_PROVIDER=ollama).
OLLAMA_URL=http://localhost:11434

# Provider keys — uncomment + set if you switch providers.
# OPENAI_API_KEY=
# VOYAGE_API_KEY=

# -----------------------------------------------------------------------------
# Phase 2.2 — reranker (optional, large quality win for hybrid search)
# -----------------------------------------------------------------------------
# Provider: cohere | voyage | noop  (default noop)
# EKG_RERANKER=
# COHERE_API_KEY=

# -----------------------------------------------------------------------------
# Phase 2.3 / Phase 3 — router + agent
# Router LLM picks retrieval strategy; agent LLM writes the final cited answer.
# -----------------------------------------------------------------------------

# openai | anthropic | ollama (default ollama)
EKG_ROUTER_PROVIDER=anthropic
EKG_AGENT_PROVIDER=anthropic

# Optional model overrides — leave blank for provider default.
# EKG_ROUTER_MODEL=
# EKG_AGENT_MODEL=

# Anthropic key — set when using anthropic for router or agent.
# Do not leave as `...`.
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Phase 4 — webhook server (optional, push-driven incremental ingest)
# Only the apps/webhook-server process reads these.
# -----------------------------------------------------------------------------

# EKG_WEBHOOK_PORT=8765
# EKG_WEBHOOK_SECRET=replace-with-a-long-random-string
# EKG_WEBHOOK_REPO_PATTERNS=org/*,other-org/svc-*
# EKG_WEBHOOK_MAX_CONCURRENT=5

# -----------------------------------------------------------------------------
# Phase 6 — external MCP adapters
# Each adapter is enabled in ekg.config.json (`mcpAdapters[].enabled = true`);
# the env vars below supply the credentials referenced by `${VAR}` in that file.
# -----------------------------------------------------------------------------

# Datadog (direct REST adapter — needs site + API/APP keys).
# DD_API_KEY=
# DD_APP_KEY=
# DD_SITE=datadoghq.com

# Atlassian — wrapped MCP server, command set in ekg.config.json.
# ATLASSIAN_TOKEN=

# Mixpanel — wrapped MCP server.
# MIXPANEL_TOKEN=

# Loki — wrapped MCP server (or direct HTTP if you swap in a custom adapter).
# LOKI_URL=https://loki.internal
