# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ekg-local-dev

# Git access (optional — for private repos)
GIT_TOKEN=

# GitLab discovery (optional — for bulk ingestion)
GITLAB_URL=https://gitlab.com
GITLAB_GROUP_IDS=

# Repo size limit (MB) — repos larger than this are skipped
MAX_REPO_SIZE_MB=1024

# Bulk ingestion concurrency (1-32)
BULK_CONCURRENCY=5

# Per-repo ingestion timeout in ms (default 10 min). Min 60s.
# A stuck clone/parse beyond this is aborted; the repo counts against retries.
INGEST_TIMEOUT_MS=600000

# Logging
LOG_LEVEL=info

# Data directory (relative to project root)
DATA_DIR=./data
